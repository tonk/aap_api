    {
      "name": "auth",
      "item": [
        {
          "name": "Create personal access token (PAT)",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/gateway/v1/tokens/",
            "description": "AAP 2.6 uses the *Platform Gateway* for OAuth2 / PAT issuance.\n  This issues a token with your username and password (HTTP Basic).\n  The token is stored in the environment variable `token` for subsequent\n  Bearer requests to `/api/gateway/v1/...`, `/api/controller/v2/...`,\n  and `/api/eda/v1/...`.\n\n  **Gateway-first on 2.6:** manage organizations, teams, users, and identity\n  (`/me`) via **`/api/gateway/v1/`** (see **gateway** and **system** folders).\n  Legacy controller RBAC mirrors remain under **legacy/** only for backward\n  compatibility testing.\n\n  Use *Hub \u2192 Create hub token* next to obtain `hubToken` for\n  `Authorization: Token \u2026` on `/api/galaxy/v3/...`.\n\n  If your admin disabled gateway basic auth, create a PAT in the UI instead\n  and paste it into the `token` environment variable.\n\n  **Environment values:** set **`baseUrl`** to a plain **`https://\u2026`** URL **without** surrounding **`\"`** in **`environments/*.bru`** and in Bruno\u2019s UI\u2014quotes are often kept as part of the value and break **`{{baseUrl}}`**. Same for **`username`** and **`password`** (no **`\"`** wrappers).\n\n  Request body uses Bruno\u2019s multiline empty JSON object form (`body:json { { } }`)\n  so Bruno **3.x** sends literal `{}`\u2014a one-line `body:json {}` can yield an empty\n  body and trigger gateway JSON parse errors.\n\n  Reference: Red Hat AAP 2.6 Automation execution API overview \u2014 OAuth2 token authentication.",
            "body": {
              "mode": "raw",
              "raw": "{\n  }",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{username}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{password}}",
                  "type": "string"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "const t = body && (body.token || body.access_token);",
                  "if (pm.response.code >= 200 && pm.response.code < 300 && t) {",
                  "    pm.environment.set(\"token\", t);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "List tokens (Basic auth)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/gateway/v1/tokens/",
            "description": "Lists gateway tokens for the authenticated user using Basic auth.\n  Useful when you do not yet have a Bearer token.",
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{username}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{password}}",
                  "type": "string"
                }
              ]
            }
          }
        }
      ]
    },
