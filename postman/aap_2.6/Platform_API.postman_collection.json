    {
      "name": "hub",
      "item": [
        {
          "name": "Create hub API token (from gateway PAT)",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/galaxy/v3/auth/token/",
            "description": "Exchanges a Platform Gateway PAT (`token` var) for a **Private Automation Hub**\n  token. The script stores it in `hubToken`. Subsequent Hub requests in this\n  collection use `Authorization: Token {{hubToken}}` (Galaxy NG style).\n\n  Run *auth/01_create-personal-access-token* first so `token` is populated.\n\n  If your Hub is on a **separate hostname**, duplicate this request with\n  `{{hubBaseUrl}}` (add that var locally) \u2014 some deployments split gateway and hub DNS.",
            "body": {
              "mode": "raw",
              "raw": "{\n  }",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "const t = body && (body.token || body.access_token);",
                  "if (pm.response.code >= 200 && pm.response.code < 300 && t) {",
                  "    pm.environment.set(\"hubToken\", t);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
