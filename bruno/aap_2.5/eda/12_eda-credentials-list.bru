meta {
  name: EDA credentials list
  type: http
  seq: 12
}

get {
  url: {{baseUrl}}/api/eda/v1/eda-credentials/
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

docs {
  AAP 2.5 replaced the older `/credentials` route with `/eda-credentials`
  for expanded credential types. Secret fields are not returned in responses.
}
