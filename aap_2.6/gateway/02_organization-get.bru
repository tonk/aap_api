meta {
  name: Organization by ID (gateway)
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/gateway/v1/organizations/{{organizationId}}/
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

docs {
  Detail for a single gateway organization. Use gateway IDs from **Organizations (gateway)** — they may differ from legacy controller numeric IDs.
}
